{
  "name": "hcxpert-qa-automation-challenge",
  "version": "1.0.0",
  "private": true,
  "description": "Desafio técnico de automação Web e API com Cypress, Cucumber e Page Object Model.",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test": "cypress run",
    "test:chrome": "cypress run --browser chrome",
    "test:chrome:headed": "powershell -ExecutionPolicy Bypass -File scripts/capture-chrome-window.ps1",
    "test:login": "cypress run --spec \"cypress/e2e/features/login.feature\"",
    "test:api": "cypress run --spec 'cypress/e2e/features/api_trello.feature'",
    "test:create-account": "cypress run --spec \"cypress/e2e/features/api_create_account.feature\"",
    "test:search": "cypress run --spec \"cypress/e2e/features/search.feature\"",
    "test:cart": "cypress run --spec \"cypress/e2e/features/add_to_cart.feature\"",
    "test:checkout": "cypress run --spec \"cypress/e2e/features/checkout.feature\"",
    "test:trello": "cypress run --spec \"cypress/e2e/features/api_Trello.feature\"",
    "report": "npm run test && node scripts/generate-report.mjs",
    "evidence:api": "node scripts/capture-api-evidencias.mjs",
    "xray:upload": "node scripts/upload-xray.mjs"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "2.2.8",
    "cypress": "15.18.1"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": [
      "cypress/e2e/step_definitions/**/*.{js,mjs,ts,tsx}"
    ],
    "json": {
      "enabled": true,
      "output": "cypress/evidencias/cucumber-report.json"
    },
    "html": {
      "enabled": true,
      "output": "cypress/evidencias/cucumber-report.html"
    }
  },
  "engines": {
    "node": ">=20"
  }
}